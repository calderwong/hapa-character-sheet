{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hapa-character-profile.schema.json",
  "title": "Hapa Character Profile",
  "type": "object",
  "required": ["schema_version", "character_id", "generated_at", "source_window", "identity", "observation_summary", "sections", "persona_adapter", "open_questions"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "character_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source_window": {
      "type": "object",
      "required": ["mode", "source_counts", "refresh_at"],
      "properties": {
        "mode": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "refresh_at": {
          "type": "string"
        },
        "source_counts": {
          "type": "object",
          "additionalProperties": {
            "type": ["integer", "number", "string"]
          }
        }
      },
      "additionalProperties": true
    },
    "identity": {
      "type": "object",
      "required": ["name", "handle", "title", "roles"],
      "properties": {
        "name": {
          "type": "string"
        },
        "handle": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "observation_summary": {
      "type": "object",
      "required": ["total_observations", "observed", "inferred", "hypothesis"],
      "properties": {
        "total_observations": {
          "type": "integer"
        },
        "observed": {
          "type": "integer"
        },
        "inferred": {
          "type": "integer"
        },
        "hypothesis": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "sections": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/profileItem"
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    },
    "persona_adapter": {
      "type": "object",
      "required": ["use_when", "priorities", "voice_rules", "decision_rules", "do_not_fake"],
      "properties": {
        "use_when": {
          "type": "string"
        },
        "priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "voice_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "do_not_fake": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "profileItem": {
      "type": "object",
      "required": ["label", "claim", "status", "confidence", "evidence"],
      "properties": {
        "label": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["observed", "inferred", "hypothesis"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "agent_use": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "observation": {
      "type": "object",
      "required": ["id", "character_id", "category", "claim", "status", "confidence", "support", "created_at", "public_safe"],
      "properties": {
        "id": {
          "type": "string"
        },
        "character_id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["trait", "motive", "voice", "lore", "relationship", "skill", "decision_rule", "risk", "agent_instruction"]
        },
        "claim": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["observed", "inferred", "hypothesis"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "support": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "counter_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agent_use": {
          "type": "string"
        },
        "public_safe": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "evidenceRef": {
      "type": "object",
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "count": {
          "type": ["integer", "number"]
        }
      },
      "additionalProperties": true
    }
  }
}
